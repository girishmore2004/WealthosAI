# Copy to .env and adjust. All defaults work with docker-compose as-is (free/local).
DATABASE_URL="postgresql://wealthos:wealthos_dev_password@localhost:5432/wealthos?schema=public"
REDIS_URL="redis://localhost:6379"
SESSION_TTL_SECONDS=2592000
API_PORT=4000
WEB_URL="http://localhost:3000"
API_URL="http://localhost:4000"
# Extra allowed CORS origins beyond WEB_URL (comma-separated) — e.g. a custom domain.
# Leave blank if WEB_URL is the only frontend origin.
CORS_EXTRA_ORIGINS=""
# Set this to your Vercel project's name prefix (e.g. "wealthos-ai-git-") to also allow
# Vercel's per-branch/PR preview URLs through CORS. Leave blank to disable (safer default).
VERCEL_PREVIEW_PREFIX=""
# Backend (Render) and frontend (Vercel) are different domains, so the session cookie
# needs SameSite=None; Secure to survive cross-site requests — this defaults to true
# whenever NODE_ENV=production. Override to "false" only if frontend and backend share
# a domain in your deployment.
CROSS_SITE_COOKIES=""
# Mock OTP adapter: OTPs are logged to the API console instead of sent via a paid SMS/email provider.
# Set to "resend" (with RESEND_API_KEY below) to actually email the code.
OTP_ADAPTER=mock
RESEND_API_KEY=""
OTP_FROM_EMAIL="WealthOS AI <onboarding@resend.dev>"
NODE_ENV=development

# --- AI Gateway (Phase 10) — see apps/api/.env.example for the full comment ---------
GROQ_API_KEY=""
GROQ_API_BASE_URL="https://api.groq.com/openai/v1"
GROQ_SMALL_MODEL="llama-3.1-8b-instant"
GROQ_LARGE_MODEL="llama-3.3-70b-versatile"
AI_REQUEST_TIMEOUT_MS=20000
AI_MAX_RETRIES=2
AI_CACHE_TTL_SECONDS=900
