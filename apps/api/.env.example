DATABASE_URL="postgresql://wealthos:wealthos_dev_password@localhost:5432/wealthos?schema=public"
REDIS_URL="redis://localhost:6379"
SESSION_TTL_SECONDS=2592000
API_PORT=4000
WEB_URL="http://localhost:3000"
# Extra allowed CORS origins beyond WEB_URL (comma-separated) — e.g. a custom domain.
CORS_EXTRA_ORIGINS=""
# Set to your Vercel project's name prefix (e.g. "wealthos-ai-git-") to also allow
# Vercel's per-branch/PR preview URLs through CORS. Leave blank to disable.
VERCEL_PREVIEW_PREFIX=""
# Render (backend) and Vercel (frontend) are different domains, so the session cookie
# needs SameSite=None; Secure to survive cross-site requests. Defaults to true whenever
# NODE_ENV=production; set to "false" only if frontend and backend share a domain.
CROSS_SITE_COOKIES=""
OTP_ADAPTER=mock
# Required when OTP_ADAPTER=resend. Get a key at https://resend.com.
RESEND_API_KEY=""
# Must be a verified sender/domain in your Resend account before it will actually send.
OTP_FROM_EMAIL="WealthOS AI <onboarding@resend.dev>"
# Local disk path for uploaded documents (free/self-hosted). Uncomment to override the
# default of ./storage/documents relative to the API process.
# DOCUMENT_STORAGE_PATH="/absolute/path/to/storage"

# --- AI Gateway (Phase 10) ---------------------------------------------------------
# Groq's free tier serves open-source models (Llama, etc.) over an OpenAI-compatible
# API — no self-hosted GPU box required. Get a key at https://console.groq.com.
# Leave unset in an environment with no AI features enabled yet; AiGatewayService
# throws AiUnavailableException on any call if this is missing, it does not crash boot.
GROQ_API_KEY=""
GROQ_API_BASE_URL="https://api.groq.com/openai/v1"
# Fast/cheap model for classification, extraction, ranking.
GROQ_SMALL_MODEL="llama-3.1-8b-instant"
# Larger model for generation, summarization, and anything needing more reasoning.
GROQ_LARGE_MODEL="llama-3.3-70b-versatile"
AI_REQUEST_TIMEOUT_MS=20000
AI_MAX_RETRIES=2
AI_CACHE_TTL_SECONDS=900
